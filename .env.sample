# OpenAlgo credentials — copy to .env and fill in
# Never commit .env to version control.

# REST API
OPENALGO_API_KEY=your_openalgo_api_key_here
OPENALGO_HOST=http://127.0.0.1:5000

# WebSocket (real-time streaming)
OPENALGO_WS_URL=ws://127.0.0.1:8765

# Optional: direct DuckDB access to Historify market data
# Default location on a stock OpenAlgo install:
#   <openalgo>/db/historify.duckdb
HISTORIFY_DUCKDB_PATH=/path/to/openalgo/db/historify.duckdb

# Optional: default strategy tag for orders (shows up in order book + analyzer logs)
OPENALGO_DEFAULT_STRATEGY=python

# Optional: WhatsApp / Telegram alert defaults
ALERT_WHATSAPP_TO=
ALERT_TELEGRAM_USERNAME=
